<launch>
  <include file='$(find livelybot_description)/launch/livelybot_description.launch' />
  <node pkg="livelybot_bringup" name="arm_joint_survey" type="arm_joint_survey" output="screen">
    <!-- Position-hold gains — moderate stiffness for slow sweeps.
         REDUCE these if the arm is too stiff / jerky. -->
    <param name="kp"              value="8.0" />
    <param name="kd"              value="1.0" />

    <!-- Sweep parameters -->
    <param name="sweep_amplitude" value="0.3" />   <!-- rad (~17 deg) -->
    <param name="hold_time"       value="3.0" />   <!-- seconds at each pose -->
    <param name="slew_rate"       value="0.3" />   <!-- rad/s ramp speed -->

    <param name="loop_rate"       value="200.0" />
    <param name="csv_path"        value="/home/hightorque/arm_joint_survey.csv" />
  </node>
</launch>
